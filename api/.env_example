# OpenAI API Key
OPENAI_API_KEY=

# API 설정
HOST=0.0.0.0
PORT=8000

# GPT 모델 설정
GPT_MODEL=gpt-4-1106-preview

# Database 설정
# 로컬 개발환경
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/chatx
# 배포 환경 (컨테이너 통신)
# DATABASE_URL=postgresql+asyncpg://chatx_user:chatx_password@chatx-postgres:5432/chatx_db

# JWT 설정
SECRET_KEY=your-secret-key-here-change-in-production

# OAuth2 설정 (DocumentAIBE와 동일)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=http://localhost:3000/login-callback/
